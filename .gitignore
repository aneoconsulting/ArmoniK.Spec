# Local install of TLA+ tools (populated by scripts/install-tools.sh)
.tlatools/

# Generated VSCode settings (rendered from .vscode/settings.json.template by
# scripts/install-tools.sh with machine-specific absolute paths). Edit the
# template, not this file.
.vscode/settings.json

# Java compiled overrides (built by `make build-java`)
*.class

# TTrace specs
*_TTrace_*.tla
*_TTrace_*.bin

# TLC generated files
*.out
*/states
*.dot

# PDF, DVI and TEX files
*.pdf
*.dvi
*.tex

# TLAPS cache folder
# See https://github.com/tlaplus/tlapm/issues/16
__tlacache__
.tlacache

# Apalache output
_apalache-out/

# Python virtualenv for helper scripts (created by `make check-sync`)
.venv/

# Python bytecode caches
__pycache__/
*.pyc
