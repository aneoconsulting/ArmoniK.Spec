    "tlaplus.tlc.modelChecker.createOutFiles": true,
    "tlaplus.tlc.modelChecker.options": "-coverage 1 -dump dot states",
    "tlaplus.tlc.statisticsSharing": "share",
    "tlaplus.pdf.convertCommand": "pdflatex",
    "tlaplus.tlc.profiler.enabled": true,
    "tlaplus.tlc.profiler.relativeScale": true,
    "tlaplus.unicode.autocomplete": true,
    "[tlaplus]": {
        "editor.codeActionsOnSave": {
            "source": "always"
        }
    },

    // ----- TLAPS ---------------------------------------------------------
    // tlapm_lsp ships in the prebuilt tlapm tarball under .tlatools/tlapm/.
    "tlaplus.tlaps.enabled": true,
    "tlaplus.tlaps.lspServerCommand": [
        "__REPO_ROOT__/.tlatools/tlapm/bin/tlapm_lsp",
        "--log-io",
        "--log-to=/tmp/tlapm_lsp.log"
    ],

    // ----- Java (for editing specs/DDGraphs.java overrides) --------------
    "java.project.referencedLibraries": [
        "__REPO_ROOT__/.tlatools/tla2tools.jar",
        "__REPO_ROOT__/.tlatools/CommunityModules-deps.jar"
    ],

    // ----- comment-box plugin (used in TLA+ files) -----------------------
    "commentBox.styles": {
        "defaultStyle": {
            "commentStartToken": "(**",
            "commentEndToken": "**)",
            "leftEdgeToken": "(* ",
            "rightEdgeToken": " *)",
            "topEdgeToken": "*",
            "bottomEdgeToken": "*",
            "topRightToken": "**)",
            "bottomLeftToken": "(**",
            "capitalize": false,
            "ignoreInnerIndentation": false,
            "ignoreOuterIndentation": false,
            "removeEmptyLines": false,
            "textAlignment": "left"
        }
    }
}
